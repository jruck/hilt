# Hilt Configuration
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

# Required: Your working folder — the top-level directory where your
# knowledge base, code, and other important context live downstream.
# Not your home folder — pick the directory that contains your projects
# and documentation (e.g., ~/work or ~/projects).
HILT_WORKING_FOLDER=

# Optional: Path to your knowledge base (weekly tasks, projects, notes).
# Only set this if your knowledge base lives outside your working folder.
# Defaults to HILT_WORKING_FOLDER.
# BRIDGE_VAULT_PATH=

# Optional: Hostname for remote access (e.g., a Tailscale machine name).
# When set, Hilt shows a local/remote switcher in the UI.
# When unset, remote access features are hidden.
# NEXT_PUBLIC_REMOTE_HOST=

# Optional: enable the local/tailnet Apps monitor.
# This exposes redacted local process/listener metadata to Hilt clients.
# HILT_LOCAL_APPS_ENABLED=true

# Optional: discover other online tailnet machines that are also running Hilt.
# Set to false to keep /api/local-apps strictly local-only.
# HILT_LOCAL_APPS_PEERS=true

# Optional: discover other online tailnet machines that are also running Hilt
# for System Sessions, Stack, Sync, and Apps aggregation.
# Set to false to keep System inspection local-only.
# HILT_SYSTEM_NETWORK_ENABLED=true

# Optional: override displayed System machine identity for demos/screenshots.
# HILT_SYSTEM_MACHINE_HOSTNAME=demo-workstation
# HILT_SYSTEM_MACHINE_DNS=demo-workstation.tailnet.example
# HILT_SYSTEM_MACHINE_IP4=100.64.0.10

# Optional: capture cached screenshots for healthy local web apps.
# Requires Playwright to be installed and is disabled by default.
# HILT_LOCAL_APPS_PREVIEWS=true

# Optional: preview screenshot cache duration in milliseconds.
# Defaults to 120000 (2 minutes).
# HILT_LOCAL_APPS_PREVIEW_CACHE_MS=120000

# Reference Library credentials
# Store real values in .env.local, not in chat or committed files.
# The CLI runner loads .env.local before reading source credentials.

# Raindrop bookmarks: https://developer.raindrop.io/v1/raindrops
# RAINDROP_TOKEN=

# YouTube liked videos. Access tokens are enough for a canary; refresh fields
# are needed for durable scheduled automation.
# YOUTUBE_OAUTH_ACCESS_TOKEN=
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# YOUTUBE_REFRESH_TOKEN=

# X/Twitter bookmarks and bookmark folders.
# Required scopes: bookmark.read tweet.read users.read offline.access
# Preferred auth is xurl, which stores its own OAuth tokens locally.
# For Bridge, use the scoped xurl build so OAuth requests only bookmark-read scopes:
#   /Users/jruck/go/bin/xurl-bridge-scoped
#   go install github.com/xdevplatform/xurl@latest
#   /Users/jruck/go/bin/xurl-bridge-scoped auth apps add bridge-library --client-id ... --client-secret ... --redirect-uri http://localhost:8080/callback
#   /Users/jruck/go/bin/xurl-bridge-scoped auth default bridge-library
#   /Users/jruck/go/bin/xurl-bridge-scoped auth oauth2 --app bridge-library
# The X Developer Portal callback URL must exactly match http://localhost:8080/callback.
# XURL_BIN=/Users/you/go/bin/xurl
# X_USE_XURL=1
# X_ACCESS_TOKEN=
# X_USER_ID=
# X_CLIENT_ID=
# X_CLIENT_SECRET=
# X_REFRESH_TOKEN=

# Superhuman News uses a remote MCP server, not an env token:
#   codex mcp add superhuman-mail --url https://mcp.mail.superhuman.com/mcp
#   codex mcp login superhuman-mail
# Hilt uses mcp-remote to reuse the local OAuth cache under ~/.mcp-auth and
# only calls the read tools list_threads/get_thread.
# SUPERHUMAN_MCP_REMOTE_BIN=

# Reference Library extraction tuning.
# Summary + source-cache extraction shell out to the summarize CLI, an external,
# separately-maintained tool (https://summarize.sh). Install it once:
#   npm i -g @steipete/summarize
# It is found on PATH by default; set SUMMARIZE_BIN to point at an explicit path
# (e.g. on a remote machine), or set LIBRARY_SUMMARIZE_DISABLED=1 to skip summaries.
# Hilt pins every model-backed call to Claude Sonnet 4.6. A machine-local
# LIBRARY_SUMMARIZE_MODEL may only restate this exact value; Google/Gemini and
# automatic provider selection are rejected before the CLI starts.
# SUMMARIZE_BIN=summarize
# LIBRARY_SUMMARIZE_DISABLED=0
# LIBRARY_SUMMARIZE_MODEL=cli/claude/claude-sonnet-4-6
# LIBRARY_SUMMARIZE_LENGTH=medium
# LIBRARY_SUMMARIZE_TIMEOUT=3m
# LIBRARY_EXTRACT_TIMEOUT=3m
# Recommendation cadence uses this IANA timezone for its one-morning/one-refresh daily limits.
# LIBRARY_RECOMMENDATION_TIME_ZONE=America/New_York
# LIBRARY_MAX_EXTRACT_CHARACTERS=200000
# LIBRARY_FULL_CONTENT_DISABLED=0
# LIBRARY_RAINDROP_CACHE_DISABLED=0
# LIBRARY_RAINDROP_CACHE_MAX_CHARS=200000
# LIBRARY_MEDIA_IMAGE_MAX=3
# LIBRARY_EXTRACT_SLIDES=0
# LIBRARY_EXTRACT_SLIDES_MAX=4
# Global xurl binary for fetching X post content (full note_tweet text via the X API). Without it,
# only sources whose yaml sets metadata.xurl_path get the authenticated path — X posts saved via
# raindrop/manual silently fall back to no-source. Point at the OAuth-registered xurl binary.
# XURL_BIN=/path/to/xurl
# YouTube clip suppression is ENFORCED by default: a confident clip/short detection skips the
# artifact before digest/reweave. Set to 0 to revert to label-only (items ingest with a badge).
# LIBRARY_YOUTUBE_CLIP_SUPPRESS=1

# Calendar ICS subscriptions.
# Private calendar feeds belong in .env.local. The US Holidays source has a
# public default feed; override it only if you prefer another public-holiday ICS.
# HILT_CALENDAR_SYNC_PAST_DAYS=730
# HILT_CALENDAR_SYNC_FUTURE_DAYS=365
# HILT_CALENDAR_ICS_EVERCOMMERCE_URL=
# HILT_CALENDAR_ICS_PRICELESS_URL=
# HILT_CALENDAR_ICS_PERSONAL_URL=
# HILT_CALENDAR_ICS_FAMILY_URL=
# HILT_CALENDAR_ICS_US_HOLIDAYS_URL=
# Optional local Fantastical bridge for EverCommerce attendee/organizer data.
# ICS remains authoritative; set to 0 to disable automatic post-sync enrichment.
# HILT_FANTASTICAL_ENRICHMENT=1
# HILT_FANTASTICAL_DB_PATH=/Users/you/Library/Group Containers/85C27NK92C.com.flexibits.fantastical2.mac/Database/Fantastical-8.fcdata
# HILT_FANTASTICAL_SNAPSHOT_PATH=/Users/you/.hilt/data/fantastical-evercommerce-calendar.json
# HILT_FANTASTICAL_EVERCOMMERCE_CALENDAR_ID=

# Granola meeting sync.
# The active Hilt service host owns the sync daemon and pulls read-only Granola
# data from the machine where Granola is signed in. In the three-Mac setup,
# Mercury runs Hilt and Apollo captures meetings in Granola. Production writes
# are blocked until Obsidian's Granola Sync plugin is disabled on both hosts.
# HILT_GRANOLA_REMOTE_HOST=apollo
# HILT_GRANOLA_REMOTE_REPO_PATH=/Users/jruck/work/engineering/me/hilt
# HILT_GRANOLA_REMOTE_NODE_PATH=/opt/homebrew/bin/node
# HILT_GRANOLA_SYNC_DAEMON=0
# HILT_GRANOLA_SYNC_DAYS_BACK=7
# HILT_GRANOLA_SYNC_POLL_MS=60000
# HILT_GRANOLA_SYNC_FAST_POLL_MS=5000
# HILT_GRANOLA_COMPARE_OUTPUT_DIR=/tmp/hilt-granola-compare
# Post-meeting extraction queue tuning. Defaults are appropriate for normal use;
# override only when diagnosing unusually long workers or retry timing.
# HILT_MEETING_TRIGGER_SETTLE_POLLS=3
# HILT_MEETING_TRIGGER_SETTLE_MS=120000
# HILT_MEETING_TRIGGER_RUN_TIMEOUT_MS=900000
# HILT_MEETING_EXTRACTION_LEASE_MS=90000
# HILT_MEETING_EXTRACTION_LEASE_RENEW_MS=30000
# HILT_MEETING_EXTRACTION_RETRY_BASE_MS=30000
# HILT_MEETING_EXTRACTION_RETRY_MAX_MS=300000
# HILT_MEETING_EXTRACTION_MAX_ATTEMPTS=5
# HILT_MEETING_EXTRACTION_RECONCILE_MS=15000

# Mercury observability dashboard (System ▸ Performance subtab).
# Hilt proxies Mercury's standalone closet/compute dashboard API (collector +
# server on Mercury's tailnet IP, port 8787). Override only if the host/port move.
# MERCURY_API_URL=http://mercury-v.tailc0acaa.ts.net:8787

# Calendar weather forecast.
# Defaults to Atlanta ZIP 30310. Set latitude/longitude together when changing
# location; Hilt uses Open-Meteo for forecast data and weather.gov for details.
# HILT_WEATHER_POSTAL_CODE=30310
# HILT_WEATHER_LOCATION_LABEL=Atlanta, GA
# HILT_WEATHER_LATITUDE=33.7269
# HILT_WEATHER_LONGITUDE=-84.4289
# HILT_WEATHER_TIMEZONE=America/New_York
