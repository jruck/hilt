# Hilt Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Required: Root folder containing your code and projects.
# Pick a directory that holds your work — NOT your home folder,
# which has too much unrelated cruft. For example: ~/work or ~/projects
HILT_WORKING_FOLDER=

# Optional: Path to your Bridge vault (weekly tasks, projects, notes).
# Defaults to HILT_WORKING_FOLDER if unset.
# BRIDGE_VAULT_PATH=

# Optional: Hostname for remote access (e.g., a Tailscale machine name).
# When set, Hilt shows a local/remote switcher in the UI.
# When unset, remote access features are hidden.
# NEXT_PUBLIC_REMOTE_HOST=
