# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.next-gateway/
/.next-devtest/
/out/

# production (Next.js output - build/ is kept for electron-builder resources)
/build/gen_icons.swift

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Git worktrees (Crystal)
/worktrees/
/worktree-*/

# User data
/data/
docs/demo/.hilt-data/

# Claude Code local settings (keep project settings tracked)
.claude/settings.local.json

# Electron
/dist-electron/
/release/

# Local files
WARP.md
local/
!src/app/api/map/local/
!src/app/api/map/local/**
.dev-port
dist/
/.obsidian
docs/.claude/settings.local.json

# Isolated dist dir for graph visual-iteration dev server
.next-graph-dev/
.next-graph-live/

# Isolated dist dir for the prod-mode daily-driver app (npm run rebuild / app:prod)
.next-prod/

# Ad-hoc tailnet-shared plan renderings (served via Next public/, not source)
/public/plans/
