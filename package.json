{
  "name": "hilt",
  "version": "7.0.0",
  "private": true,
  "main": "electron/main.js",
  "packageManager": "npm@10.9.4",
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10 <11"
  },
  "scripts": {
    "dev": "tsx server/app-server.ts",
    "dev:webpack": "next dev -H ${HOST:-0.0.0.0} -p ${PORT:-3000}",
    "build": "next build",
    "build:gateway": "NEXT_PUBLIC_BASE_PATH=/hilt HILT_DIST_DIR=.next-gateway next build",
    "start": "NODE_ENV=production tsx server/app-server.ts",
    "start:gateway": "NODE_ENV=production NEXT_PUBLIC_BASE_PATH=/hilt HILT_DIST_DIR=.next-gateway tsx server/app-server.ts",
    "lint": "eslint",
    "test:map": "tsx --test src/lib/map/**/*.test.ts",
    "test:bridge": "tsx --test src/lib/bridge/weekly-parser.test.ts src/lib/bridge/area-parser.test.ts src/lib/bridge/area-goal-context.test.ts src/lib/bridge/briefing-files.test.ts src/lib/bridge/briefing-link-targets.test.ts src/lib/bridge/briefing-status.test.ts && vitest run src/lib/bridge/people-parser.test.ts",
    "test:calendar": "tsx --test src/lib/calendar/**/*.test.ts",
    "test:granola": "tsx --test src/lib/granola/**/*.test.ts",
    "test:graph": "tsx --test src/lib/graph/**/*.test.ts",
    "test:semantic": "tsx --test src/lib/semantic/**/*.test.ts",
    "semantic": "DATA_DIR=${DATA_DIR:-$HOME/.hilt/data} tsx scripts/semantic.ts",
    "semantic:topics": "DATA_DIR=${DATA_DIR:-$HOME/.hilt/data} tsx scripts/semantic.ts topics",
    "semantic:backfill": "DATA_DIR=${DATA_DIR:-$HOME/.hilt/data} tsx scripts/semantic-backfill.ts",
    "semantic:backfill:cold": "DATA_DIR=${DATA_DIR:-$HOME/.hilt/data} tsx scripts/semantic-backfill.ts cold-start",
    "semantic:gc": "DATA_DIR=${DATA_DIR:-$HOME/.hilt/data} tsx scripts/semantic-backfill.ts gc",
    "semantic:resolve": "DATA_DIR=${DATA_DIR:-$HOME/.hilt/data} tsx scripts/semantic-resolve.ts",
    "semantic:refit": "DATA_DIR=${DATA_DIR:-$HOME/.hilt/data} tsx scripts/semantic-refit.ts",
    "semantic:scheduler:plan": "tsx scripts/semantic-scheduler.ts",
    "semantic:scheduler:install": "tsx scripts/semantic-scheduler.ts --install",
    "semantic:scheduler:uninstall": "tsx scripts/semantic-scheduler.ts --uninstall",
    "test:semantic:e2e": "tsx scripts/semantic-e2e.ts",
    "test:graph:e2e": "tsx scripts/graph-e2e.ts",
    "test:calendar:e2e": "tsx scripts/calendar-e2e.ts",
    "calendar:import-fantastical-cache": "DATA_DIR=${DATA_DIR:-$HOME/.hilt/data} tsx scripts/calendar-import-fantastical-cache.ts",
    "calendar:audit-ics": "DATA_DIR=${DATA_DIR:-$HOME/.hilt/data} tsx scripts/calendar-audit-ics.ts",
    "test:weather": "tsx --test src/lib/weather/**/*.test.ts",
    "test:map:perf": "tsx --test src/lib/map/**/*.perf.ts",
    "test:system": "tsx --test src/lib/system/system.test.ts",
    "test:system:sync-live": "tsx scripts/system-sync-smoke.ts",
    "test:local-apps": "tsx --test src/lib/local-apps/**/*.test.ts",
    "test:library": "tsx --test src/lib/library/**/*.test.ts",
    "test:references": "tsx --test src/lib/references/**/*.test.ts",
    "test:briefing": "tsx --test src/lib/briefing/**/*.test.ts",
    "briefing:generate": "DATA_DIR=${DATA_DIR:-$HOME/.hilt/data} tsx scripts/briefing-generate.ts",
    "briefing:shadow": "DATA_DIR=${DATA_DIR:-$HOME/.hilt/data} tsx scripts/briefing-generate.ts --mode auto --shadow",
    "briefing:daily": "DATA_DIR=${DATA_DIR:-$HOME/.hilt/data} tsx scripts/briefing-generate.ts --mode auto",
    "briefing:retry": "DATA_DIR=${DATA_DIR:-$HOME/.hilt/data} tsx scripts/briefing-retry.ts",
    "briefing:scheduler:plan": "tsx scripts/briefing-scheduler.ts",
    "briefing:scheduler:install": "tsx scripts/briefing-scheduler.ts --install",
    "briefing:scheduler:uninstall": "tsx scripts/briefing-scheduler.ts --uninstall",
    "test:server-mode": "tsx --test server/server-mode.test.ts",
    "test:system-agent": "tsx --test server/system-agent.test.ts",
    "test:system-agent:e2e": "tsx scripts/system-agent-e2e.ts",
    "test:system-agent:parity": "tsx scripts/system-agent-parity.ts",
    "test:system-agent:smoke": "tsx scripts/system-agent-smoke.ts",
    "test:system-agent:all": "npm run test:system-agent && npm run test:system-agent:e2e && npm run test:system-agent:parity",
    "system-agent:run": "tsx server/system-agent.ts",
    "system-agent:install": "tsx scripts/system-agent-launchd.ts --install",
    "system-agent:uninstall": "tsx scripts/system-agent-launchd.ts --uninstall",
    "system-agent:status": "tsx scripts/system-agent-launchd.ts --status",
    "metrics:import": "tsx scripts/metrics-import.ts",
    "metrics:collect-once": "tsx scripts/metrics-collect-once.ts",
    "test:metrics": "tsx --test src/lib/system/telemetry/telemetry.test.ts",
    "test:vitest": "vitest run src/hooks/__tests__/useEventSocket.test.ts src/app/api/reveal/route.test.ts src/lib/db.test.ts src/lib/landing-view.test.ts",
    "test:unit": "npm run test:map && npm run test:bridge && npm run test:calendar && npm run test:granola && npm run test:graph && npm run test:semantic && npm run test:weather && npm run test:system && npm run test:local-apps && npm run test:library && npm run test:server-mode && npm run test:system-agent && npm run test:vitest",
    "test": "npm run test:unit && npx tsc --noEmit",
    "test:local-apps:parity": "tsx scripts/local-apps-parity.ts",
    "demo:seed-map": "DATA_DIR=${DATA_DIR:-./docs/demo/.hilt-data} tsx scripts/seed-demo-map.ts",
    "demo:seed-calendar-link": "DATA_DIR=${DATA_DIR:-./docs/demo/.hilt-data} tsx scripts/seed-demo-calendar-link.ts",
    "dev:demo": "npm run demo:seed-map && DATA_DIR=./docs/demo/.hilt-data HILT_WORKING_FOLDER=./docs/demo BRIDGE_VAULT_PATH=./docs/demo HILT_SYSTEM_NETWORK_ENABLED=false HILT_SYSTEM_MACHINE_HOSTNAME=demo-workstation HILT_SYSTEM_MACHINE_DNS=demo-workstation.tailnet.example HILT_SYSTEM_MACHINE_IP4=100.64.0.10 HILT_CALENDAR_FIXTURE_MODE=1 HILT_WEATHER_FIXTURE_MODE=1 HILT_CALENDAR_SYNC_PAST_DAYS=30 HILT_CALENDAR_SYNC_FUTURE_DAYS=90 npm run dev",
    "screenshots": "tsx scripts/capture-screenshots.ts",
    "library:ingest": "tsx scripts/library-ingest.ts",
    "library:backfill": "tsx scripts/library-ingest.ts backfill",
    "library:audit-quality": "tsx scripts/library-quality-audit.ts",
    "library:redigest": "tsx scripts/library-redigest.ts",
    "library:repair-legacy": "tsx scripts/library-repair-legacy-references.ts",
    "library:repair-body-cruft": "tsx scripts/library-repair-body-cruft.ts",
    "library:repair-media": "tsx scripts/library-repair-media.ts",
    "library:repair-taxonomy": "tsx scripts/library-repair-source-taxonomy.ts",
    "library:book:import": "tsx scripts/library-import-book-capture.ts",
    "library:reweave": "tsx scripts/library-reweave.ts",
    "library:reweave:pending": "tsx scripts/library-reweave-pending.ts --write",
    "library:reweave:pending:dry-run": "tsx scripts/library-reweave-pending.ts",
    "library:reweave:nightly": "DATA_DIR=${DATA_DIR:-$HOME/.hilt/data} tsx scripts/library-reweave-pending.ts --write --limit 40 --include-version-behind",
    "library:steering": "DATA_DIR=${DATA_DIR:-$HOME/.hilt/data} tsx scripts/library-steering.ts",
    "library:judge": "DATA_DIR=${DATA_DIR:-$HOME/.hilt/data} tsx scripts/library-judge-sample.ts",
    "library:metrics": "DATA_DIR=${DATA_DIR:-$HOME/.hilt/data} tsx scripts/library-metrics.ts --markdown",
    "library:memo": "DATA_DIR=${DATA_DIR:-$HOME/.hilt/data} tsx scripts/library-memo.ts",
    "library:refetch": "DATA_DIR=${DATA_DIR:-$HOME/.hilt/data} tsx scripts/library-refetch.ts",
    "library:x:recover": "DATA_DIR=${DATA_DIR:-$HOME/.hilt/data} tsx scripts/library-x-recover.ts",
    "library:recover": "DATA_DIR=${DATA_DIR:-$HOME/.hilt/data} tsx scripts/library-recover.ts",
    "library:x:videos": "DATA_DIR=${DATA_DIR:-$HOME/.hilt/data} tsx scripts/library-x-video-transcripts.ts",
    "library:repair-youtube-liked": "tsx scripts/library-repair-youtube-liked.ts",
    "library:youtube:clips:report": "tsx scripts/library-youtube-clip-report.ts",
    "library:semantic:calibrate": "DATA_DIR=${DATA_DIR:-$HOME/.hilt/data} HILT_SEMANTIC_ENABLED=true tsx scripts/library-semantic-calibrate.ts",
    "library:semantic:headtohead": "DATA_DIR=${DATA_DIR:-$HOME/.hilt/data} HILT_SEMANTIC_ENABLED=true tsx scripts/library-semantic-headtohead.ts",
    "library:semantic:delta": "DATA_DIR=${DATA_DIR:-$HOME/.hilt/data} HILT_SEMANTIC_ENABLED=true tsx scripts/library-semantic-delta.ts",
    "library:auth": "tsx scripts/library-ingest.ts auth",
    "library:ingest:dry-run": "tsx scripts/library-ingest.ts --dry-run --limit 5",
    "library:migrate-references": "tsx scripts/library-migrate-references.ts",
    "library:youtube:oauth": "tsx scripts/library-youtube-oauth.ts",
    "library:ingest:hourly": "tsx scripts/library-ingest.ts hourly",
    "library:ingest:newsletters": "tsx scripts/library-ingest.ts daily-newsletters",
    "library:candidates:cleanup": "tsx scripts/library-ingest.ts cleanup",
    "library:retry": "tsx scripts/library-ingest.ts retry",
    "library:recommendations": "DATA_DIR=${DATA_DIR:-$HOME/.hilt/data} tsx scripts/library-editor-pass.ts",
    "library:scheduler:plan": "tsx scripts/library-scheduler.ts",
    "library:scheduler:install": "tsx scripts/library-scheduler.ts --install",
    "library:scheduler:uninstall": "tsx scripts/library-scheduler.ts --uninstall",
    "granola:status": "DATA_DIR=${DATA_DIR:-$HOME/.hilt/data} tsx scripts/granola-sync.ts status",
    "granola:compare": "DATA_DIR=${DATA_DIR:-$HOME/.hilt/data} tsx scripts/granola-sync.ts compare",
    "granola:sync": "DATA_DIR=${DATA_DIR:-$HOME/.hilt/data} tsx scripts/granola-sync.ts incremental",
    "granola:sync:write": "DATA_DIR=${DATA_DIR:-$HOME/.hilt/data} tsx scripts/granola-sync.ts incremental --write",
    "granola:backfill": "DATA_DIR=${DATA_DIR:-$HOME/.hilt/data} tsx scripts/granola-sync.ts backfill",
    "granola:backfill:write": "DATA_DIR=${DATA_DIR:-$HOME/.hilt/data} tsx scripts/granola-sync.ts backfill --write",
    "granola:augment-existing": "DATA_DIR=${DATA_DIR:-$HOME/.hilt/data} tsx scripts/granola-sync.ts augment-existing",
    "granola:augment-existing:write": "DATA_DIR=${DATA_DIR:-$HOME/.hilt/data} tsx scripts/granola-sync.ts augment-existing --write",
    "granola:audit-unmatched": "DATA_DIR=${DATA_DIR:-$HOME/.hilt/data} tsx scripts/granola-audit-unmatched.ts",
    "granola:handoff-status": "DATA_DIR=${DATA_DIR:-$HOME/.hilt/data} tsx scripts/granola-sync.ts handoff-status",
    "granola:handoff-disable": "DATA_DIR=${DATA_DIR:-$HOME/.hilt/data} tsx scripts/granola-sync.ts handoff-disable",
    "granola:handoff-restore": "DATA_DIR=${DATA_DIR:-$HOME/.hilt/data} tsx scripts/granola-sync.ts handoff-restore",
    "serve:gateway": "concurrently \"npm run start:gateway\" \"npm run ws-server\"",
    "supervisor:run": "tsx server/supervisor.ts",
    "supervisor:install": "tsx scripts/supervisor-launchd.ts --install",
    "supervisor:uninstall": "tsx scripts/supervisor-launchd.ts --uninstall",
    "supervisor:status": "tsx scripts/supervisor-launchd.ts --status",
    "ws-server": "tsx server/ws-server.ts",
    "event-server": "tsx server/event-server.ts",
    "dev:all": "concurrently \"DATA_DIR=$HOME/.hilt/data npm run dev\" \"DATA_DIR=$HOME/.hilt/data npm run ws-server\" \"DATA_DIR=$HOME/.hilt/data npm run event-server\"",
    "doctor:local": "node scripts/doctor-local.mjs",
    "verify:desktop": "node scripts/verify-desktop.mjs",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron electron/launcher.cjs\"",
    "app": "npm run doctor:local && npm run electron:compile && bash scripts/create-dev-app.sh && npm run verify:desktop",
    "app:prod": "npm run doctor:local && npm run rebuild && npm run electron:compile && HILT_APP_MODE=prod bash scripts/create-dev-app.sh && npm run verify:desktop",
    "rebuild": "HILT_DIST_DIR=.next-prod next build && node -e \"require('fs').writeFileSync('.next-prod/.hilt-rebuild-stamp', new Date().toISOString())\"",
    "start:prod": "HILT_DIST_DIR=.next-prod npm run start",
    "electron:create-dev-app": "npm run doctor:local && bash scripts/create-dev-app.sh && npm run verify:desktop",
    "electron:build": "npm run build && cp -r .next/static .next/standalone/.next/static && cp -r public .next/standalone/public && npm run electron:compile",
    "electron:dist": "npm run electron:build && electron-builder",
    "electron:dist:mac": "npm run electron:build && electron-builder --mac",
    "electron:compile:watch": "tsc -p electron/tsconfig.json --watch"
  },
  "dependencies": {
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.2",
    "@cosmos.gl/graph": "^2.6.4",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@lezer/markdown": "^1.6.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@schedule-x/calendar": "^4.6.0",
    "@schedule-x/calendar-controls": "^4.6.0",
    "@schedule-x/current-time": "^4.6.0",
    "@schedule-x/event-modal": "^4.6.0",
    "@schedule-x/events-service": "^4.6.0",
    "@schedule-x/react": "^4.1.0",
    "@schedule-x/scroll-controller": "^4.6.0",
    "@schedule-x/theme-default": "^4.6.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-virtual": "^3.13.13",
    "@tiptap/extension-file-handler": "^3.18.0",
    "@tiptap/extension-floating-menu": "^3.18.0",
    "@tiptap/extension-image": "^3.18.0",
    "@tiptap/extension-link": "^3.18.0",
    "@tiptap/extension-placeholder": "^3.18.0",
    "@tiptap/extension-table": "^3.18.0",
    "@tiptap/extension-table-cell": "^3.18.0",
    "@tiptap/extension-table-header": "^3.18.0",
    "@tiptap/extension-table-row": "^3.18.0",
    "@tiptap/extension-task-item": "^3.18.0",
    "@tiptap/extension-task-list": "^3.18.0",
    "@tiptap/extension-typography": "^3.18.0",
    "@tiptap/pm": "^3.18.0",
    "@tiptap/react": "^3.18.0",
    "@tiptap/starter-kit": "^3.18.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@uiw/react-codemirror": "^4.25.4",
    "agentation": "^2.2.1",
    "better-sqlite3": "^12.10.0",
    "bplist-parser": "^0.3.2",
    "chokidar": "^5.0.0",
    "gray-matter": "^4.0.3",
    "ical.js": "^2.2.1",
    "lucide-react": "^0.562.0",
    "mcp-remote": "^0.1.38",
    "mermaid": "^11.12.2",
    "next": "16.2.5",
    "ngraph.forcelayout": "^3.3.1",
    "ngraph.graph": "^20.1.2",
    "playwright": "^1.60.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^3.20.0",
    "swr": "^2.3.8",
    "temporal-polyfill": "0.3.0",
    "tiptap-markdown": "^0.9.0",
    "uuid": "^13.0.0",
    "web-haptics": "^0.0.6",
    "ws": "^8.18.3",
    "yaml": "^2.8.2",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.5",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.7",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.hilt.app",
    "productName": "Hilt",
    "directories": {
      "output": "dist"
    },
    "files": [
      ".next/**/*",
      "electron/**/*.js",
      "src/**/*",
      "server/**/*",
      "public/**/*",
      "package.json"
    ],
    "asar": false,
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "dmg": {
      "title": "Hilt"
    }
  }
}
