# Hilt Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Required: Root folder where your knowledge base, working code, and other
# important context live downstream. Not your home folder — pick the directory
# that contains your projects and documentation (e.g., ~/work or ~/projects).
HILT_WORKING_FOLDER=

# Optional: Path to your knowledge base (weekly tasks, projects, notes).
# Defaults to HILT_WORKING_FOLDER if unset.
# BRIDGE_VAULT_PATH=

# Optional: Hostname for remote access (e.g., a Tailscale machine name).
# When set, Hilt shows a local/remote switcher in the UI.
# When unset, remote access features are hidden.
# NEXT_PUBLIC_REMOTE_HOST=
